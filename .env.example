# AI API Keys
VITE_ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
VITE_OPENAI_API_KEY=sk-xxxxxxxxxxxx
VITE_GEMINI_API_KEY=AIzaxxxxxxxxxxxx

# Backend API
VITE_API_URL=http://localhost:3001
VITE_API_TIMEOUT=30000

# Feature Flags
VITE_ENABLE_AUTH=true
VITE_ENABLE_BACKEND=false
VITE_ENABLE_ANALYTICS=false

# Storage
VITE_STORAGE_TYPE=local
VITE_MAX_STORAGE_SIZE=50

# Chat Settings
VITE_MAX_CHAT_HISTORY=100
VITE_MAX_TOKENS=2000
VITE_DEFAULT_TEMPERATURE=0.7

# Rate Limiting
VITE_API_RATE_LIMIT=100
VITE_API_RATE_WINDOW=3600

# Debug
VITE_DEBUG_MODE=false
